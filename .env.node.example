# Environment Variables for Node.js Runtime

# Sqlite3 Database URL
DATABASE_URL="file:./db.sqlite"

# Bootstrap first admin (only when user table is empty)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"
ADMIN_NAME="Admin"

# File Storage
FILE_STORAGE="base64" # Options: "base64"(default), "disk", "r2"

# Local File Storage Configuration
# FILE_STORAGE_DISK_PATH=".files"

# Application mode: must be mixed for multi-user server mode
MODE="mixed"

# Enable Cloudflare built-in AI (workers only)
# PROVIDER_CLOUDFLARE_BUILTIN="false"
